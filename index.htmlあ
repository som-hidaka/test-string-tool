function rep(c, n) { return c.repeat(n); }

var customBoundaryItems = [];

function applyBoundary() {
  var minLen = parseInt(document.getElementById('minLen').value);
  var maxLen = parseInt(document.getElementById('maxLen').value);
  var minType = document.getElementById('minType').value;
  var maxType = document.getElementById('maxType').value;
  customBoundaryItems = [];
  var preview = document.getElementById('boundaryPreview');
  var rows = [];
  var allFields = ['text','email','tel','number','password','url','search'];

  function makeChar(type) { return type === 'full' ? 'あ' : 'a'; }
  function typeLabel(type) { return type === 'full' ? '全角' : '半角'; }

  if (!isNaN(minLen) && minLen >= 0) {
    var ch = makeChar(minType);
    var tl = typeLabel(minType);
    if (minLen > 0) customBoundaryItems.push({cat:'boundary', label:'最小-1 (' + (minLen-1) + '文字・' + tl + ')', value:rep(ch, minLen-1), desc:'最小文字数を下回る', fields:allFields});
    customBoundaryItems.push({cat:'boundary', label:'最小 (' + minLen + '文字・' + tl + ')', value:rep(ch, minLen), desc:'最小文字数ちょうど', fields:allFields});
    customBoundaryItems.push({cat:'boundary', label:'最小+1 (' + (minLen+1) + '文字・' + tl + ')', value:rep(ch, minLen+1), desc:'最小文字数を上回る', fields:allFields});
    rows.push('最小(' + tl + '): ' + (minLen > 0 ? (minLen-1)+'文字 / ' : '') + minLen+'文字 / '+(minLen+1)+'文字');
  }
  if (!isNaN(maxLen) && maxLen >= 1) {
    var ch2 = makeChar(maxType);
    var tl2 = typeLabel(maxType);
    customBoundaryItems.push({cat:'boundary', label:'最大-1 (' + (maxLen-1) + '文字・' + tl2 + ')', value:rep(ch2, maxLen-1), desc:'最大文字数を下回る', fields:allFields});
    customBoundaryItems.push({cat:'boundary', label:'最大 (' + maxLen + '文字・' + tl2 + ')', value:rep(ch2, maxLen), desc:'最大文字数ちょうど', fields:allFields});
    customBoundaryItems.push({cat:'boundary', label:'最大+1 (' + (maxLen+1) + '文字・' + tl2 + ')', value:rep(ch2, maxLen+1), desc:'最大文字数を超過', fields:allFields});
    rows.push('最大(' + tl2 + '): '+(maxLen-1)+'文字 / '+maxLen+'文字 / '+(maxLen+1)+'文字');
  }
  if (rows.length) {
    preview.innerHTML = '<div style="font-size:12px;color:#27ae60;background:#eafaf1;border-radius:4px;padding:6px 10px">✅ ' + rows.join('　／　') + ' を生成しました</div>';
  } else {
    preview.innerHTML = '<div style="font-size:12px;color:#e74c3c">最小文字数か最大文字数を入力してください</div>';
  }
  renderList();
}

function clearBoundary() {
  customBoundaryItems = [];
  document.getElementById('minLen').value = '';
  document.getElementById('maxLen').value = '';
  document.getElementById('boundaryPreview').innerHTML = '';
  renderList();
}

var activeField = null;
var activeCat = 'all';

var grid = document.getElementById('fieldGrid');
FIELDS.forEach(function(f) {
  var btn = document.createElement('button');
  btn.className = 'field-btn';
  btn.innerHTML = '<span class="icon">' + f.icon + '</span><span class="name">' + f.name + '</span>';
  btn.onclick = (function(fid, b){ return function(){ selectField(fid, b); }; })(f.id, btn);
  grid.appendChild(btn);
});

function selectField(id, btn) {
  activeField = id;
  activeCat = 'all';
  document.querySelectorAll('.field-btn').forEach(function(b){ b.classList.remove('active'); });
  btn.classList.add('active');
  document.getElementById('step2').style.display = '';
  renderCatTabs();
  renderList();
}

function renderCatTabs() {
  var tabs = document.getElementById('catTabs');
  tabs.innerHTML = CATS.map(function(c) {
    return '<button class="cat-tab' + (c.id === activeCat ? ' active' : '') + '" onclick="selectCat(\'' + c.id + '\')">' + c.label + '</button>';
  }).join('');
}

function selectCat(id) {
  activeCat = id;
  renderCatTabs();
  renderList();
}

function renderList() {
  var base = customBoundaryItems.concat(ALL_ITEMS);
  var items = base.filter(function(item) {
    return (activeField === 'all' || item.fields.indexOf(activeField) !== -1) &&
           (activeCat === 'all' || item.cat === activeCat);
  });
  document.getElementById('resultCount').textContent = items.length + ' 件';
  var list = document.getElementById('stringList');
  if (!items.length) {
    list.innerHTML = '<div class="empty">該当する文字列がありません</div>';
    return;
  }
  var html = '';
  items.forEach(function(item, idx) {
    var display = item.value === '' ? '（空文字）' : esc(item.value).substring(0, 300) + (item.value.length > 300 ? '...' : '');
    html += '<div class="string-item">';
    html += '<span class="cat-badge badge-' + item.cat + '">' + catLabel(item.cat) + '</span>';
    html += '<div class="string-meta">';
    html += '<div class="string-label">' + esc(item.label) + '</div>';
    html += '<div class="string-value">' + display + '</div>';
    html += '<div class="string-desc">' + esc(item.desc) + '</div>';
    html += '</div>';
    html += '<button class="copy-btn" data-idx="' + idx + '">コピー</button>';
    html += '</div>';
  });
  list.innerHTML = html;
  list.querySelectorAll('.copy-btn').forEach(function(btn) {
    var idx = parseInt(btn.getAttribute('data-idx'));
    btn.onclick = function() { copyStr(btn, items[idx].value); };
  });
}

function esc(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function catLabel(c) {
  var m = {boundary:'境界値',special:'特殊文字',sql:'SQL',xss:'XSS',japanese:'日本語',emoji:'絵文字',unicode:'Unicode'};
  return m[c] || c;
}
function copyStr(btn, val) {
  navigator.clipboard.writeText(val).then(function() {
    btn.textContent = 'コピー済!';
    btn.classList.add('copied');
    setTimeout(function(){ btn.textContent = 'コピー'; btn.classList.remove('copied'); }, 1500);
  });
}
</script>
</body>
</html>
